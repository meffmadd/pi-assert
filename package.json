{
  "name": "pi-assert",
  "version": "0.1.0",
  "description": "Shell-assertion guard for pi. Reads asserts.json to block tool calls that fail user-defined shell checks.",
  "type": "module",
  "main": "./pi-assert/index.ts",
  "files": [
    "pi-assert/",
    "skills/",
    "AGENTS.md"
  ],
  "keywords": [
    "pi",
    "guard",
    "security",
    "assert",
    "shell"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./pi-assert/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pretest": "npm run typecheck && npm run lint",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-tui": "^0.79.3",
    "ajv": "^8.20.0",
    "eslint": "^9.39.4",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
